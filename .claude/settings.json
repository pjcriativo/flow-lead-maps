{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(npm install)",
      "Bash(npm run:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(supabase functions deploy:*)",
      "Bash(supabase secrets:*)",
      "Bash(supabase link:*)",
      "Bash(supabase projects:*)",
      "Bash(npx supabase functions deploy:*)",
      "Bash(npx supabase secrets:*)",
      "Bash(npx supabase link:*)",
      "Bash(npx supabase projects:*)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(supabase db reset:*)",
      "Bash(npx supabase db reset:*)",
      "Read(.env)",
      "Write(.env)",
      "Edit(.env)"
    ]
  }
}
