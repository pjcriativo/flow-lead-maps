node_modules
dist

# Segredos — NUNCA versionar (.env e variantes, exceto o template)
.env
.env.*
!.env.example

# Artefatos de build (TanStack Start / Nitro / Cloudflare / Vite)
.output
.wrangler
.nitro
.vite
.tanstack

# Arquivos sensíveis / não versionar
contas.txt
*.zip

# Skills: os symlinks em .claude/skills/* usam caminho ABSOLUTO da máquina
# (não portáveis). O conteúdo real fica em .agents/skills/ (versionado).
# Exceção: flow-loop é arquivo real e deve ser versionado.
/.claude/skills/*
!/.claude/skills/flow-loop

.vercel
.env*
