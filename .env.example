# Flow Leads — Variáveis de ambiente (MESTRE DO MVP)
# Copie para .env e preencha. NUNCA commite o .env.

# Supabase (obrigatório) — projeto do MESTRE DO MVP
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Mesmo valor da anon key (nome que o client do frontend espera)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Versões sem prefixo VITE_ para o lado SSR (Nitro/process.env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Backend da busca de leads (placeholder até plugar Google Places)
VITE_API_BASE=http://localhost:8000

# Uso administrativo (NÃO expor no frontend) — só em ambiente servidor
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_ACCESS_TOKEN=...
